{
  "//": "Lighthouse-CI budget gate. Closes gap R3/C2. INSTALL: copy to repo root as lighthouserc.json; CI job runs it (see test.yml). Fails the build if mobile scores regress below target.",
  "ci": {
    "collect": {
      "url": [
        "https://cyberdudebivash.in/",
        "https://cyberdudebivash.in/pricing.html",
        "https://cyberdudebivash.in/tools.html"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "perf",
        "emulatedFormFactor": "mobile",
        "throttlingMethod": "simulate"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.95, "aggregationMethod": "median" }],
        "categories:accessibility": ["error", { "minScore": 1.0 }],
        "categories:seo": ["error", { "minScore": 1.0 }],
        "categories:best-practices": ["error", { "minScore": 1.0 }],
        "largest-contentful-paint": ["error", { "maxNumericValue": 2500 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 200 }],
        "interactive": ["warn", { "maxNumericValue": 3800 }]
      }
    },
    "upload": { "target": "temporary-public-storage" }
  }
}
