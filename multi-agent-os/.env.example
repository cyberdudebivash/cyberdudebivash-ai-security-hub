# CYBERDUDEBIVASH® MACOS — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.

# Infrastructure
DATABASE_URL=postgresql://cdb:cdb_secret@localhost:5432/cdb_macos
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
KAFKA_BROKERS=localhost:9092

# AI Providers — Set at least ONE of these. Anthropic is OPTIONAL.
GROQ_API_KEY=            # Recommended: fast, free tier available
DEEPSEEK_API_KEY=        # Cost-optimized for compliance/research tasks
OPENROUTER_API_KEY=      # Universal fallback
CF_ACCOUNT_ID=           # Cloudflare account (Workers AI)
CF_API_TOKEN=            # Cloudflare API token
ANTHROPIC_API_KEY=       # OPTIONAL — platform works without this

# Auth
ADMIN_API_KEY=cdb-macos-admin-2026
JWKS_URL=                # Keycloak: https://your-keycloak/realms/cdb/protocol/openid-connect/certs

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
GRAFANA_PASSWORD=change_this_in_production

# Application
ENVIRONMENT=development
WORKERS=4
ALLOWED_ORIGINS=https://cyberdudebivash.in,http://localhost:3000
