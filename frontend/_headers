# =============================================================================
# CYBERDUDEBIVASH AI Security Hub — Cloudflare Pages Response Headers v9.0
# =============================================================================
# CRITICAL: HTML must never be cached. JS/CSS can be cached if versioned.
# Root cause of "stale v8 showing after v9 deploy" was the /* rule below
# applying max-age=3600 to index.html. Now fixed with explicit HTML no-store.
# =============================================================================

# ── Security headers on ALL routes ──────────────────────────────────────────
/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://*.workers.dev https://cyberdudebivash.in https://*.cyberdudebivash.in; font-src 'self'; frame-ancestors 'none'; form-action 'self' https://rzp.io;
  X-Powered-By: CYBERDUDEBIVASH AI Security Hub v18.0
  Vary: Accept-Encoding

# ── HTML — NEVER cache, always fresh ────────────────────────────────────────
# This is the critical fix. index.html must be served fresh on every request
# so users immediately see the latest deployment without manual cache busting.
/
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/index.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/*.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

# ── version.json — never cache (CI injects build-time values here) ───────────
/version.json
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Content-Type: application/json; charset=utf-8

# ── API routes — never cache ──────────────────────────────────────────────────
/api/*
  Cache-Control: no-store, no-cache

# ── Versioned static assets — cache forever (immutable) ──────────────────────
# Only applies to assets that have a hash/version in filename (e.g. app.v9.js)
# These are safe to cache immutably because filename changes on each deploy.
/*.v9.*
  Cache-Control: public, max-age=31536000, immutable

# ── JSON data files — short cache (except version.json handled above) ────────
/data/*.json
  Content-Type: application/json; charset=utf-8
  Cache-Control: public, max-age=300, stale-while-revalidate=600

# ── XML sitemaps ─────────────────────────────────────────────────────────────
/sitemap.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=86400

/robots.txt
  Cache-Control: public, max-age=86400

# ── OG image — explicit Content-Type essential for social crawlers ────────────
# LinkedIn/WhatsApp/Twitter bots fetch this directly and MUST get image/png.
# The _redirects file ensures this path is served before SPA catch-all fires.
/og-image.png
  Content-Type: image/png
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
  X-Content-Type-Options: nosniff

/assets/ai-security-hub-banner.png
  Content-Type: image/png
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
  X-Content-Type-Options: nosniff

# ── Static assets (images, fonts, icons) — moderate cache ────────────────────
/*.png
  Content-Type: image/png
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
  X-Content-Type-Options: nosniff
/*.jpg
  Content-Type: image/jpeg
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
/*.jpeg
  Content-Type: image/jpeg
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
/*.webp
  Content-Type: image/webp
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
/*.svg
  Content-Type: image/svg+xml
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
/*.ico
  Content-Type: image/x-icon
  Cache-Control: public, max-age=604800, stale-while-revalidate=86400
/*.woff2
  Content-Type: font/woff2
  Cache-Control: public, max-age=31536000, immutable
/*.woff
  Content-Type: font/woff
  Cache-Control: public, max-age=31536000, immutable
