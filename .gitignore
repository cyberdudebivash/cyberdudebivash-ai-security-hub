# ── Deployment scripts & emergency fix logs (never commit) ────────────────────
*.bat
*.ps1
fix_deploy*.txt
*_result.txt

# ── Staged commit message drafts (already committed — leftover artifacts) ─────
commit_p*.txt

# ── Audit & generated output files ───────────────────────────────────────────
CYBERDUDEBIVASH_KV_AUDIT_REPORT.docx
tools_output/
workspace/

# ── Large binary artifacts / accidental repo snapshots ───────────────────────
# Source archives must never be committed (they bloat every clone and drift
# from the live tree). Build/release artifacts belong in CI artifact storage,
# not git. See ARTIFACT_RETENTION_POLICY.md.
*.zip

# ── Temporary files ───────────────────────────────────────────────────────────
*.tmp
*.bak
*.orig
.wrangler/state/

# ── Local runtime artifacts (SQLite dev DB, agent memory) ─────────────────────
# NB: anchored to repo root so the tracked ai-core/memory package is unaffected.
*.db
/cdb_ai.db
/memory/
/logs/

# CVE SEO generator data exports (transient)
tools/_cve_raw.json
tools/_cve_export.json
tools/_cve_err.txt
