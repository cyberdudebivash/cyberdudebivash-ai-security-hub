# ============================================================
# CYBERDUDEBIVASH AI — ENVIRONMENT TEMPLATE
# Copy to .env and fill all values. NEVER commit .env
# ============================================================

# ── REQUIRED ─────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_64_char_random_hex_string_do_not_use_default

# ── App ───────────────────────────────────────────────────────
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# ── AI ────────────────────────────────────────────────────────
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=60

# ── Database ─────────────────────────────────────────────────
# SQLite (default — fine for single-node):
DATABASE_URL=sqlite:////data/cdb_ai.db
# PostgreSQL (recommended for production scale):
# DATABASE_URL=postgresql://user:password@host:5432/cdb_ai

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── CORS (comma-separated origins) ───────────────────────────
# Development: CORS_ORIGINS=http://localhost:3000
# Production: CORS_ORIGINS=https://your-domain.com
CORS_ORIGINS=http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT=100
RATE_LIMIT_WINDOW=60

# ── Celery ───────────────────────────────────────────────────
CELERY_CONCURRENCY=4
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=360

# ── Memory ───────────────────────────────────────────────────
MEMORY_DIR=/app/memory

# ── Cybersecurity ─────────────────────────────────────────────
THREAT_INTEL_ENABLED=true
SCAN_TIMEOUT=30

# ── Payments: UPI / Razorpay only across the SENTINEL APEX ecosystem.
# Stripe is not an authorized processor — see api/billing.py PAYMENT
# METHOD MANDATE (Threat Intel Platform repo).
# Required by generated_app/routers/payment.py — no insecure defaults,
# the service refuses to start without PAYMENT_ADMIN_SECRET set.
PAYMENT_ADMIN_SECRET=replace_with_random_secret_do_not_use_default
PAYMENT_UPI_IDS=your-upi-id@bank,your-secondary-upi-id@bank
BANK_ACCOUNT_NAME=
BANK_ACCOUNT_NUMBER=
BANK_IFSC=
BANK_NAME=
PAYPAL_EMAIL=
CRYPTO_BNB_ADDRESS=
