{
  "ci": {
    "collect": {
      "url": ["http://localhost:3000/"],
      "numberOfRuns": 1,
      "settings": {
        "emulatedFormFactor": "mobile",
        "throttlingMethod": "simulate",
        "onlyCategories": ["performance", "accessibility", "seo", "best-practices"]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance":    ["error", { "minScore": 0.40, "aggregationMethod": "median" }],
        "categories:accessibility":  ["error", { "minScore": 0.65, "aggregationMethod": "median" }],
        "categories:seo":            ["error", { "minScore": 0.80, "aggregationMethod": "median" }],
        "categories:best-practices": ["error", { "minScore": 0.70, "aggregationMethod": "median" }],
        "largest-contentful-paint":  ["error", { "maxNumericValue": 6000, "aggregationMethod": "median" }],
        "cumulative-layout-shift":   ["error", { "maxNumericValue": 0.25, "aggregationMethod": "median" }],
        "total-blocking-time":       ["warn",  { "maxNumericValue": 1000 }],
        "interactive":               ["warn",  { "maxNumericValue": 15000 }]
      }
    },
    "upload": { "target": "temporary-public-storage" }
  }
}
